{
  "cleanUrls": true,

  "rewrites": [
    {
      "source": "/join-group/:token",
      "destination": "/join?token=:token"
    },
    {
      "source": "/join-group/:token/:rest*",
      "destination": "/join?token=:token"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
